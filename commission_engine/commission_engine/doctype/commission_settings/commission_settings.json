    "fields": [
        {
            "fieldname": "first_invoice_section",
            "fieldtype": "Section Break",
            "label": "First Invoice (One-Time) Commission Rates",
            "description": "Default rates for the FIRST invoice to a customer. Can be overridden per person below."
        },
        {
            "default": "10",
            "fieldname": "onetime_salesperson_pct",
            "fieldtype": "Percent",
            "label": "Default Salesperson Commission %",
            "description": "E.g. 10 means 10% of invoice net amount",
            "reqd": 1
        },
        {
            "default": "2",
            "fieldname": "onetime_manager_pct",
            "fieldtype": "Percent",
            "label": "Default Manager Commission %",
            "description": "E.g. 2 means 2% of invoice net amount",
            "reqd": 1
        },
        {
            "fieldname": "col_break1",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "recurring_section",
            "fieldtype": "Section Break",
            "label": "Recurring Invoice Commission Rates",
            "description": "Default rates for all subsequent invoices. Can be overridden per person below."
        },
        {
            "default": "5",
            "fieldname": "recurring_salesperson_pct",
            "fieldtype": "Percent",
            "label": "Default Salesperson Commission %",
            "description": "E.g. 5 means 5% of invoice net amount",
            "reqd": 1
        },
        {
            "default": "1",
            "fieldname": "recurring_manager_pct",
            "fieldtype": "Percent",
            "label": "Default Manager Commission %",
            "description": "E.g. 1 means 1% of invoice net amount",
            "reqd": 1
        },
        {
            "fieldname": "col_break2",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "override_section",
            "fieldtype": "Section Break",
            "label": "Individual Rate Overrides",
            "description": "Override commission rates for specific salespersons or managers. Leave blank to use the global defaults above."
        },
        {
            "fieldname": "commission_rate_overrides",
            "fieldtype": "Table",
            "label": "Rate Overrides",
            "options": "Commission Rate Override",
            "description": "Add rows here only for people who need a different rate than the defaults above"
        },
        {
            "fieldname": "tier_section",
            "fieldtype": "Section Break",
            "label": "Tiered Commission Rates",
            "description": "Optional: define rate tiers based on cumulative monthly sales. When enabled, these override default rates.",
            "collapsible": 1
        },
        {
            "default": "0",
            "fieldname": "enable_tiered_commission",
            "fieldtype": "Check",
            "label": "Enable Tiered Commission",
            "description": "When enabled, commission rates are determined by cumulative sales for the month"
        },
        {
            "fieldname": "commission_tiers",
            "fieldtype": "Table",
            "label": "Commission Tiers",
            "options": "Commission Tier",
            "depends_on": "eval:doc.enable_tiered_commission",
            "description": "From Amount → To Amount → Commission %. Set 'To Amount' to 0 for unlimited."
        },
        {
            "fieldname": "controls_section",
            "fieldtype": "Section Break",
            "label": "Controls & Thresholds"
        },
        {
            "default": "0",
            "fieldname": "enable_approval_workflow",
            "fieldtype": "Check",
            "label": "Enable Approval Workflow",
            "description": "When enabled, commissions must be Approved before they can be marked as Paid"
        },
        {
            "default": "0",
            "fieldname": "minimum_commission_threshold",
            "fieldtype": "Currency",
            "label": "Minimum Commission Threshold",
            "description": "Don't create commission entries below this amount (0 = no minimum)"
        },
        {
            "fieldname": "col_break3",
            "fieldtype": "Column Break"
        },
        {
            "default": "0",
            "fieldname": "maximum_commission_cap",
